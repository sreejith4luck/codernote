import React, { useState, useRef, useEffect } from 'react';
import { Plus, X, AlertCircle, CheckCircle, Search } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { SectionType } from '../types';
import { MedicalCode } from '../data';

interface CodingQueueCardProps {
  title: string;
  section: SectionType;
  tags: string[];
  onDeleteTag: (section: SectionType, tag: string) => void;
  onAddTag: (section: SectionType, tag: string) => void;
  inputValue: string;
  onInputChange: (section: SectionType, value: string) => void;
  placeholder: string;
  suggestions?: MedicalCode[];
  badgeText: string;
  accentColor: 'green' | 'red' | 'blue' | 'pink';
  inputRef: React.RefObject<HTMLInputElement | null>;
  isErrorShake: boolean;
  onAdvanceFocus: () => void;
}

export default function CodingQueueCard({
  title,
  section,
  tags,
  onDeleteTag,
  onAddTag,
  inputValue,
  onInputChange,
  placeholder,
  suggestions,
  badgeText,
  accentColor,
  inputRef,
  isErrorShake,
  onAdvanceFocus
}: CodingQueueCardProps) {
  const [isFocused, setIsFocused] = useState(false);
  const containerRef = useRef<HTMLDivElement>(null);

  const handleTextChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    let value = e.target.value.toUpperCase();
    if (section.includes('Cpt')) {
      // CPT only allow digits
      value = value.replace(/\D/g, '');
    } else {
      // Diagnostic codes allow letters, digits, and dots
      value = value.replace(/[^A-Z0-9.]/g, '');
    }
    onInputChange(section, value);
  };

  const submitCurrentInput = () => {
    const val = inputValue.trim().toUpperCase();
    if (!val) {
      onAdvanceFocus();
      return;
    }

    if (section.includes('Cpt') && val.length !== 5) {
      return; // Handled by validation warnings triggers externally or internally
    }

    onAddTag(section, val);
  };

  const handleKeyDown = (e: React.KeyboardEvent<HTMLInputElement>) => {
    if (e.key === 'Enter' || e.key === 'Tab') {
      // If there is text, try to add it. Let the main app validation kick in.
      if (inputValue.trim()) {
        e.preventDefault();
        submitCurrentInput();
      } else if (e.key === 'Enter') {
        // Empty + enter navigates
        e.preventDefault();
        onAdvanceFocus();
      }
    } else if (e.key === 'Backspace' && !inputValue && tags.length > 0) {
      // Delete last tag if field is empty
      onDeleteTag(section, tags[tags.length - 1]);
    }
  };

  // Color config mappings for stunning responsive borders and outlines
  const colorSchemes = {
    green: {
      border: 'border-emerald-200/80 focus-within:border-emerald-500 focus-within:ring-2 focus-within:ring-emerald-500/10 dark:border-emerald-800/40 dark:focus-within:border-emerald-500/80',
      badge: 'bg-emerald-50 text-emerald-700 border-emerald-150 dark:bg-emerald-950/40 dark:text-emerald-400 dark:border-emerald-900/30',
      dot: 'bg-emerald-500 shadow-emerald-500/20',
      banner: 'bg-emerald-50/20 dark:bg-emerald-950/10',
      tag: 'bg-emerald-50/80 hover:bg-emerald-100/90 text-emerald-800 border-emerald-200/60 dark:bg-emerald-950/30 dark:hover:bg-emerald-900/40 dark:text-emerald-300 dark:border-emerald-800/30',
      button: 'bg-emerald-600 hover:bg-emerald-700 text-white shadow-emerald-600/10'
    },
    red: {
      border: 'border-rose-200/80 focus-within:border-rose-500 focus-within:ring-2 focus-within:ring-rose-500/10 dark:border-rose-800/40 dark:focus-within:border-rose-500/80',
      badge: 'bg-rose-50 text-rose-700 border-rose-150 dark:bg-rose-950/40 dark:text-rose-400 dark:border-rose-900/30',
      dot: 'bg-rose-500 shadow-rose-500/20',
      banner: 'bg-rose-50/20 dark:bg-rose-950/10',
      tag: 'bg-rose-50/80 hover:bg-rose-100/90 text-rose-800 border-rose-200/60 dark:bg-rose-950/30 dark:hover:bg-rose-900/40 dark:text-rose-300 dark:border-rose-850/30',
      button: 'bg-rose-600 hover:bg-rose-700 text-white shadow-rose-600/10'
    },
    blue: {
      border: 'border-blue-200/80 focus-within:border-blue-500 focus-within:ring-2 focus-within:ring-blue-500/10 dark:border-blue-800/40 dark:focus-within:border-blue-500/80',
      badge: 'bg-blue-50 text-blue-700 border-blue-150 dark:bg-blue-950/40 dark:text-blue-400 dark:border-blue-900/30',
      dot: 'bg-blue-500 shadow-blue-500/20',
      banner: 'bg-blue-50/20 dark:bg-slate-950/10',
      tag: 'bg-blue-50/80 hover:bg-blue-100/90 text-blue-850 border-blue-200/60 dark:bg-blue-950/30 dark:hover:bg-blue-900/40 dark:text-blue-300 dark:border-blue-800/30',
      button: 'bg-blue-600 hover:bg-blue-700 text-white shadow-blue-600/10'
    },
    pink: {
      border: 'border-pink-200/80 focus-within:border-pink-500 focus-within:ring-2 focus-within:ring-pink-500/10 dark:border-pink-805/40 dark:focus-within:border-pink-500/80',
      badge: 'bg-pink-50 text-pink-700 border-pink-150 dark:bg-pink-950/40 dark:text-pink-400 dark:border-pink-900/30',
      dot: 'bg-pink-500 shadow-pink-500/20',
      banner: 'bg-pink-50/20 dark:bg-pink-950/10',
      tag: 'bg-pink-50/80 hover:bg-pink-100/90 text-pink-800 border-pink-200/60 dark:bg-pink-950/30 dark:hover:bg-pink-900/40 dark:text-pink-300 dark:border-pink-850/30',
      button: 'bg-pink-600 hover:bg-pink-700 text-white shadow-pink-600/10'
    }
  };

  const currentScheme = colorSchemes[accentColor] || colorSchemes.blue;

  // Real-time local validation indicator
  const getValidationFeedback = () => {
    if (!inputValue) return null;
    if (section.includes('Cpt')) {
      if (inputValue.length < 5) {
        return (
          <span className="flex items-center gap-1 text-[11px] font-medium text-amber-600 dark:text-amber-400 leading-none">
            <AlertCircle className="h-3.5 w-3.5" />
            Needs 5 digits (typed: {inputValue.length})
          </span>
        );
      }
      if (inputValue.length === 5) {
        return (
          <span className="flex items-center gap-1 text-[11px] font-medium text-emerald-600 dark:text-emerald-400 leading-none">
            <CheckCircle className="h-3.5 w-3.5" />
            Valid CPT Format
          </span>
        );
      }
    } else {
      return (
        <span className="flex items-center gap-1 text-[11px] font-medium text-blue-500 dark:text-blue-400 leading-none">
          <CheckCircle className="h-3.5 w-3.5" />
          Press Add
        </span>
      );
    }
    return null;
  };

  return (
    <motion.div
      initial={{ opacity: 0, y: 15 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.3, ease: 'easeOut' }}
      className={`relative flex flex-col bg-[var(--card-bg)] rounded-2xl border ${isErrorShake ? 'animate-error' : 'border-[var(--border-light)]'} shadow-sm hover:shadow-md transition-all duration-300`}
      ref={containerRef}
    >
      {/* CARD HEADER */}
      <div className="flex items-center justify-between px-5 py-4 border-b border-[var(--border-light)] bg-slate-50/40 dark:bg-slate-900/20 rounded-t-2xl">
        <div className="flex items-center gap-2">
          <div className={`h-2.5 w-2.5 rounded-full ${currentScheme.dot} animate-pulse`}></div>
          <span className="text-xs font-extrabold uppercase tracking-widest text-[var(--text-main)] font-display">
            {title}
          </span>
        </div>
        <span className={`text-[10px] px-2.5 py-0.5 rounded-md font-bold uppercase tracking-wider border border-[var(--border-light)] ${currentScheme.badge}`}>
          {badgeText}
        </span>
      </div>

      {/* QUEUED TAGS VIEWPORT */}
      <div className={`p-5 flex-1 min-h-[110px] flex flex-wrap gap-2 items-start content-start cursor-text ${currentScheme.banner}`}>
        {tags.length === 0 ? (
          <div className="w-full h-full flex flex-col items-center justify-center py-4 text-center">
            <span className="text-xs text-[var(--text-muted)] italic font-medium">No codes listed in this queue.</span>
          </div>
        ) : (
          <AnimatePresence>
            {tags.map(tag => (
              <motion.span
                key={tag}
                initial={{ opacity: 0, scale: 0.8 }}
                animate={{ opacity: 1, scale: 1 }}
                exit={{ opacity: 0, scale: 0.8 }}
                className={`inline-flex items-center gap-1.5 px-3 py-1 rounded-xl text-xs font-bold font-mono border transition-all ${currentScheme.tag}`}
              >
                {tag}
                <button
                  type="button"
                  onClick={() => onDeleteTag(section, tag)}
                  className="hover:text-red-500 opacity-60 hover:opacity-100 transition-opacity ml-1 cursor-pointer p-0.5 rounded-sm focus:outline-hidden"
                  aria-label={`Remove code ${tag}`}
                >
                  <X className="h-3 w-3" />
                </button>
              </motion.span>
            ))}
          </AnimatePresence>
        )}
      </div>

      {/* FOOTER INPUT CONTROLS */}
      <div className="absolute top-0 right-0" />
      <div className="p-4 bg-white dark:bg-transparent border-t border-[var(--border-light)] rounded-b-2xl space-y-3">
        {/* Interactive Search input container with built-in action icons */}
        <div className="relative">
          {isFocused && (
            <div className="absolute inset-[-2px] rounded-xl overflow-hidden pointer-events-none z-0">
              <div className="absolute top-1/2 left-1/2 h-[300%] w-[300%] bg-[conic-gradient(from_180deg,#ff007f,#7f00ff,#00f0ff,#00ff7f,#ff007f)] animate-rotate-glow pointer-events-none" />
            </div>
          )}
          <div className={`relative z-10 flex items-center bg-[var(--card-bg)] rounded-xl border transition-all px-3 py-2 ${currentScheme.border}`}>
          <Search className="h-4 w-4 text-[var(--text-muted)] mr-2 shrink-0" />
          <input
            ref={inputRef}
            type="text"
            value={inputValue}
            onChange={handleTextChange}
            onKeyDown={handleKeyDown}
            onFocus={() => {
              setIsFocused(true);
            }}
            onBlur={() => {
              setIsFocused(false);
            }}
            placeholder={placeholder}
            className="flex-1 min-w-0 bg-transparent text-sm font-semibold outline-hidden text-[var(--text-main)] placeholder-[var(--text-muted)] uppercase tracking-wide font-mono"
            aria-label={`Search and enter ${title}`}
          />
          
          {/* Action button right inside the input field */}
          <button
            type="button"
            onClick={submitCurrentInput}
            className={`w-7 h-7 flex items-center justify-center rounded-lg transition-transform active:scale-95 cursor-pointer ml-1.5 shrink-0 ${currentScheme.button}`}
            title="Add to queue"
          >
            <Plus className="h-4 w-4 stroke-[3]" />
          </button>
        </div>
      </div>

        {/* Real-time validation warning shelf */}
        <div className="flex items-center justify-between min-h-[16px] px-1">
          {getValidationFeedback() || (
            <span className="text-[10.5px] text-[var(--text-muted)] italic leading-none font-medium">
              Enter or click + to add custom
            </span>
          )}
          <span className="text-[10.5px] text-[var(--brand-blue)] hover:underline cursor-pointer select-none font-bold outline-hidden uppercase tracking-wider" onClick={onAdvanceFocus}>
            Jump Field &rarr;
          </span>
        </div>
      </div>
    </motion.div>
  );
}
